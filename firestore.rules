rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────
    // Any authenticated user can read any profile (needed for role checks).
    // Users can only write their own profile document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if false;
    }

    // ── Trips ────────────────────────────────────────────────────────────
    match /trips/{tripId} {
      // Any authenticated user can read trips (passengers need this).
      allow read: if request.auth != null;

      // Only conductors can create trips.
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'conductor';

      // Only the trip's own conductor can update, and only while the trip
      // is still active (prevents editing completed trips).
      allow update: if request.auth != null
        && resource.data.conductorId == request.auth.uid
        && resource.data.status == 'active';

      // Trips are never deleted – they persist as history.
      allow delete: if false;
    }

    // ── Buses ────────────────────────────────────────────────────────────
    // Conductors can manage their own buses.
    // Any authenticated user can read (passengers need bus info).
    match /buses/{busId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && resource.data.conductorId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.conductorId == request.auth.uid;
    }

    // ── Routes ──────────────────────────────────────────────────────────
    // Any authenticated user can read routes (passengers search them).
    // Conductors can create and update routes.
    match /routes/{routeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
